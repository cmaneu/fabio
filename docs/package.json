{
  "name": "fabio-docs",
  "version": "0.0.0",
  "private": true,
  "description": "Documentation website for the Fabio CLI",
  "scripts": {
    "dev": "npm run generate:reference && astro dev",
    "build": "npm run generate:reference && astro build",
    "preview": "astro preview",
    "generate:reference": "node scripts/generate-reference.mjs",
    "check": "npm run generate:reference && astro check",
    "test": "node --test scripts/generate-reference.test.mjs"
  },
  "type": "module",
  "dependencies": {
    "@astrojs/starlight": "0.41.4",
    "astro": "7.1.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "typescript": "6.0.3"
  }
}
