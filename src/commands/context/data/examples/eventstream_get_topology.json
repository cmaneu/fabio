{
  "command": "fabio eventstream get-topology --workspace $WS_ID --id $ES_ID",
  "description": "Returns the eventstream topology showing sources, destinations, streams, and their connections.",
  "response": {
    "data": {
      "sources": [
        {
          "name": "app-events-source",
          "type": "CustomEndpoint",
          "status": "Running",
          "id": "c1d2e3f4-0000-0000-0000-000000000001"
        }
      ],
      "destinations": [
        {
          "name": "kql-sink",
          "type": "Eventhouse",
          "status": "Running",
          "id": "c1d2e3f4-0000-0000-0000-000000000003",
          "properties": {
            "dataIngestionMode": "DirectIngestion",
            "workspaceId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
            "itemId": "d4e5f6a7-0000-0000-0000-000000000010",
            "tableName": "SensorEvents"
          }
        }
      ],
      "streams": [
        {
          "name": "app-events-source-stream",
          "status": "Created",
          "inputNodes": ["app-events-source"]
        }
      ],
      "operators": []
    }
  },
  "notes": "Sources feed into streams, streams feed into destinations/operators. Status values: Creating, Running, Warning, Stopped. Destination itemId must be the KQL Database ID (NOT Eventhouse ID). CustomEndpoint sources expose Event Hub-compatible interface for sending events.",
  "query_examples": [
    {"query": "data.sources[].name", "description": "List all source names."},
    {"query": "data.destinations[?status=='Running'].name", "description": "Active destinations."},
    {"query": "data.destinations[].properties.tableName", "description": "Target table names."},
    {"query": "data.streams[].inputNodes", "description": "Stream input connections."}
  ]
}
