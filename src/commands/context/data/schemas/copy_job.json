{
  "type": "CopyJob",
  "description": "Automated data copy job that moves data between sources and destinations (e.g., from Azure SQL to a lakehouse). Supports scheduled and on-demand execution.",
  "create_command": "fabio copy-job create --workspace <WS> --name <NAME>",
  "definition_format": null,
  "definition_parts": [
    {"path": "CopyJobV1.json", "description": "Copy job configuration with source/destination mappings"}
  ],
  "creation_body_template": {
    "displayName": "{{name}}"
  },
  "flags": {
    "--name": "Copy job display name",
    "--description": "Optional description"
  },
  "notes": [
    "Create is LRO",
    "getDefinition sends empty body {} (LRO)",
    "updateDefinition is LRO",
    "Reset allows re-copying: --all or --entity-ids (mutually exclusive)",
    "Required roles: Create/Delete need Member; Update/Definition need Contributor"
  ],
  "related_commands": [
    "fabio copy-job get-definition --workspace <WS> --id <ID>",
    "fabio copy-job update-definition --workspace <WS> --id <ID> --file <FILE>",
    "fabio copy-job reset --workspace <WS> --id <ID> --all",
    "fabio copy-job list --workspace <WS>",
    "fabio copy-job delete --workspace <WS> --id <ID>"
  ]
}
